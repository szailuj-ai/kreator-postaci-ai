<script is:inline>
  var HASLO = "wdupietrzaslo";
  var poleHasla = document.getElementById('pole-hasla');
  var btnOko = document.getElementById('btn-oko');
  var svgOko = document.getElementById('svg-oko');
  var btnStrzalka = document.getElementById('btn-strzalka');
  var widoczne = false;

  btnOko.addEventListener('click', function() {
    widoczne = !widoczne;
    if (widoczne) {
      poleHasla.classList.remove('ukryte');
      svgOko.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    } else {
      poleHasla.classList.add('ukryte');
      svgOko.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    }
  });

  function sprawdzHaslo() {
    if (poleHasla.value === HASLO) {
      document.getElementById('ekran-hasla').style.display = 'none';
      document.getElementById('strona-glowna').style.display = 'block';
      aktualizujPodglad();
    } else {
      document.getElementById('blad-hasla').style.display = 'block';
    }
  }

  btnStrzalka.addEventListener('click', sprawdzHaslo);
  poleHasla.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') sprawdzHaslo();
  });

  document.getElementById('btn-podglad-toggle').addEventListener('click', function() {
    var panel = document.getElementById('panel-podglad');
    var btn = document.getElementById('btn-podglad-toggle');
    if (panel.style.display === 'block') {
      panel.style.display = 'none';
      btn.textContent = 'Karta postaci \u2193';
    } else {
      panel.style.display = 'block';
      btn.textContent = 'Karta postaci \u2191';
      aktualizujPodglad();
    }
  });

  document.getElementById('podglad-btn-wyczysc').addEventListener('click', function() {
    document.getElementById('podglad-tresc').textContent = 'Wypełnij formularz aby zobaczyć podgląd...';
  });

  document.getElementById('podglad-btn-kopiuj').addEventListener('click', function() {
    var tresc = document.getElementById('podglad-tresc').textContent;
    if (tresc) navigator.clipboard.writeText(tresc);
  });

  document.querySelectorAll('.segment-naglowek').forEach(function(naglowek) {
    naglowek.addEventListener('click', function() {
      var tresc = naglowek.nextElementSibling;
      var strzalka = naglowek.querySelector('.segment-strzalka');
      if (tresc.classList.contains('widoczny')) {
        tresc.classList.remove('widoczny');
        strzalka.classList.remove('otwarty');
        strzalka.textContent = '\u2193';
      } else {
        tresc.classList.add('widoczny');
        strzalka.classList.add('otwarty');
        strzalka.textContent = '\u2191';
      }
    });
  });

  function setupOpcje(grupa) {
    var max = parseInt(grupa.getAttribute('data-max')) || 1;
    grupa.querySelectorAll('.opcja').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (btn.classList.contains('zablokowana')) return;
        if (btn.classList.contains('aktywna')) {
          btn.classList.remove('aktywna');
          odblokujOpcje(grupa);
        } else {
          var aktywne = grupa.querySelectorAll('.opcja.aktywna').length;
          if (aktywne < max) {
            btn.classList.add('aktywna');
            if (aktywne + 1 >= max) zablokujNieaktywne(grupa);
          }
        }
        aktualizujPodglad();
      });
    });
  }

  function zablokujNieaktywne(grupa) {
    grupa.querySelectorAll('.opcja:not(.aktywna)').forEach(function(b) { b.classList.add('zablokowana'); });
  }

  function odblokujOpcje(grupa) {
    var max = parseInt(grupa.getAttribute('data-max')) || 1;
    if (grupa.querySelectorAll('.opcja.aktywna').length < max) {
      grupa.querySelectorAll('.opcja').forEach(function(b) { b.classList.remove('zablokowana'); });
    }
  }

  document.querySelectorAll('.opcje').forEach(function(g) { setupOpcje(g); });

  var zasadyZawsze = [];
  var zasadyNigdy = [];

  var losowaniaZawsze = [
    "Uses sarcasm and irony to comment on intelligence or behavior",
    "Challenges the credibility of the interlocutor, assuming everyone lies",
    "Forms hypotheses based on the least obvious details",
    "Explains difficult concepts using simple metaphors",
    "Asks clarifying questions before answering",
    "Summarizes at the end of each response",
    "Points out alternative solutions",
    "Checks the interlocutor's understanding",
    "Uses concrete examples to illustrate points",
    "References earlier threads in the conversation",
    "Analyzes problems from multiple perspectives",
    "Warns about potential consequences",
    "Acknowledges when something is outside their knowledge",
    "Asks one question at the end of each response",
    "Maintains consistency with previous answers",
    "Distinguishes facts from opinions",
    "Highlights key information",
    "Responds to the emotional state of the interlocutor",
    "Uses humor when the situation allows",
    "Proposes next steps after analysis",
    "Cites sources when relevant",
    "Thinks out loud when facing difficult problems",
    "Applies the method of elimination",
    "References cultural context when appropriate",
    "Adapts communication style to the interlocutor",
    "Asks clarifying questions before making judgments",
    "Maintains neutrality on controversial issues",
    "Points out gaps in the interlocutor's reasoning",
    "Summarizes conclusions before moving on",
    "Ends responses with a concrete takeaway"
  ];

  var losowaniaNigdy = [
    "Apologizes for their opinion",
    "Avoids difficult topics",
    "Pretends to be certain when they are not",
    "Ignores contradictions in statements",
    "Uses filler phrases like 'obviously' or 'as everyone knows'",
    "Uses empty motivational clichés",
    "Judges the interlocutor as a person",
    "Ignores questions without a response",
    "Changes position without justification",
    "Applies double standards",
    "Answers without understanding the question",
    "Drops a thread without explanation",
    "Ignores the emotions of the interlocutor",
    "Lies even when the truth is uncomfortable",
    "Gives evasive answers to direct questions",
    "Trivializes the interlocutor's problems",
    "Uses emotional manipulation",
    "Gives advice without understanding the context",
    "Hides their own limitations",
    "Confirms incorrect assumptions",
    "Uses language of superiority without reason",
    "Ignores signs of misunderstanding",
    "Uses time pressure tactics",
    "Oversimplifies complex issues without noting it",
    "Agrees without genuine conviction",
    "Avoids responsibility for incorrect information",
    "Uses passive aggression",
    "Ignores a request to change the topic",
    "Hides their own assumptions",
    "Ends a conversation without a clear summary"
  ];

  function renderZasady(typ) {
    var lista = typ === 'zawsze' ? zasadyZawsze : zasadyNigdy;
    var el = document.getElementById('lista-' + typ);
    el.innerHTML = '';
    lista.forEach(function(z, i) {
      var div = document.createElement('div');
      div.style.cssText = 'display:flex;gap:8px;align-items:center;margin-bottom:8px';
      var input = document.createElement('input');
      input.type = 'text';
      input.value = z;
      input.style.cssText = 'flex:1;padding:8px 12px;border:1px solid #e0e0e0;font-size:0.85rem;font-family:inherit;outline:none';
      input.addEventListener('input', function() { lista[i] = input.value; aktualizujPodglad(); });
      var btnX = document.createElement('button');
      btnX.textContent = '\u00d7';
      btnX.style.cssText = 'background:none;border:none;cursor:pointer;color:#aaa;font-size:1.2rem;padding:0';
      btnX.addEventListener('click', function() { lista.splice(i, 1); renderZasady(typ); });
      div.appendChild(input);
      div.appendChild(btnX);
      el.appendChild(div);
    });
    aktualizujPodglad();
  }

  document.getElementById('dodaj-zawsze').addEventListener('click', function() {
    if (zasadyZawsze.length < 10) { zasadyZawsze.push(''); renderZasady('zawsze'); }
  });

  document.getElementById('dodaj-nigdy').addEventListener('click', function() {
    if (zasadyNigdy.length < 10) { zasadyNigdy.push(''); renderZasady('nigdy'); }
  });

  document.getElementById('losuj-zawsze').addEventListener('click', function() {
    if (zasadyZawsze.length < 10) {
      var d = losowaniaZawsze.filter(function(l) { return zasadyZawsze.indexOf(l) === -1; });
      if (d.length) { zasadyZawsze.push(d[Math.floor(Math.random() * d.length)]); renderZasady('zawsze'); }
    }
  });

  document.getElementById('losuj-nigdy').addEventListener('click', function() {
    if (zasadyNigdy.length < 10) {
      var d = losowaniaNigdy.filter(function(l) { return zasadyNigdy.indexOf(l) === -1; });
      if (d.length) { zasadyNigdy.push(d[Math.floor(Math.random() * d.length)]); renderZasady('nigdy'); }
    }
  });

  function pobierzOpcje(pole) {
    var el = document.querySelector('[data-pole="' + pole + '"]');
    if (!el) return '';
    return Array.from(el.querySelectorAll('.opcja.aktywna')).map(function(b) { return b.getAttribute('data-val'); }).join(', ');
  }

  function wyczyscWszystko() {
    ['imie', 'wiek', 'wiedza', 'historia', 'jezyk', 'otwarta'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.value = '';
    });
    document.querySelectorAll('.opcja').forEach(function(b) {
      b.classList.remove('aktywna');
      b.classList.remove('zablokowana');
    });
    zasadyZawsze.length = 0;
    zasadyNigdy.length = 0;
    renderZasady('zawsze');
    renderZasady('nigdy');
    document.getElementById('wynik').style.display = 'none';
    aktualizujPodglad();
  }

  document.getElementById('btn-wyczysc-karte').addEventListener('click', wyczyscWszystko);

  function aktualizujPodglad() {
    var imie = document.getElementById('imie').value;
    var wiek = document.getElementById('wiek').value;
    var wiedza = document.getElementById('wiedza').value;
    var jezyk = document.getElementById('jezyk').value;
    var historia = document.getElementById('historia').value;

    var t = '';
    if (imie) t += 'Name: ' + imie + '\n';
    if (wiek) t += 'Age/Stage: ' + wiek + '\n';
    if (wiedza) t += 'Expertise: ' + wiedza + '\n';
    if (historia) t += 'Background: ' + historia.substring(0, 120) + (historia.length > 120 ? '...' : '') + '\n';

    var pola = [
      ['dlugosc','Response length'],['ton','Tone'],['slownictwo','Vocabulary'],
      ['nawyki','Language habits'],['emoji','Emoji'],['humor','Humor']
    ];
    var kom = pola.map(function(p) {
      var v = pobierzOpcje(p[0]);
      return v ? p[1] + ': ' + v : '';
    }).filter(Boolean);
    if (jezyk) kom.push('Language: ' + jezyk);
    if (kom.length) t += '\n--- Communication ---\n' + kom.join('\n') + '\n';

    var pola2 = [
      ['tempo','Thinking pace'],['prawda','Approach to truth'],['pryzmat','Worldview'],
      ['nastawienie','Attitude'],['styl','Work style'],['koncentracja','Focus'],['detale','Attention to detail']
    ];
    var osob = pola2.map(function(p) { var v = pobierzOpcje(p[0]); return v ? p[1] + ': ' + v : ''; }).filter(Boolean);
    if (osob.length) t += '\n--- Personality ---\n' + osob.join('\n') + '\n';

    var pola3 = [
      ['myslenie','Thinking style'],['niewiedza','When uncertain'],
      ['wyzwanie','Challenge level'],['ryzyko','Risk attitude']
    ];
    var mysl = pola3.map(function(p) { var v = pobierzOpcje(p[0]); return v ? p[1] + ': ' + v : ''; }).filter(Boolean);
    if (mysl.length) t += '\n--- Thinking Style ---\n' + mysl.join('\n') + '\n';

    var pola4 = [
      ['dynamika','Dynamic'],['inicjatywa','Initiative'],['feedback','Feedback style'],
      ['dopytuje','Follow-up questions'],['dopytuje2','Additionally asks about'],
      ['granice','Boundaries'],['dystans','Emotional distance'],
      ['reakcja','Reaction to success/failure'],['tryb','Interaction mode']
    ];
    var rel = pola4.map(function(p) { var v = pobierzOpcje(p[0]); return v ? p[1] + ': ' + v : ''; }).filter(Boolean);
    if (rel.length) t += '\n--- Relationship ---\n' + rel.join('\n') + '\n';

    var pola5 = [
      ['format','Format'],['przyklady','Examples'],['jakie-przyklady','Example types'],
      ['cytaty','Citations'],['tok','Reasoning shown'],['specjalistyczne','Specialist vocabulary']
    ];
    var forma = pola5.map(function(p) { var v = pobierzOpcje(p[0]); return v ? p[1] + ': ' + v : ''; }).filter(Boolean);
    if (forma.length) t += '\n--- Response Format ---\n' + forma.join('\n') + '\n';

    var zawsze = zasadyZawsze.filter(function(z){return z;});
    var nigdy = zasadyNigdy.filter(function(z){return z;});
    if (zawsze.length) { t += '\n--- Always ---\n'; zawsze.forEach(function(z){ t += '\u2022 ' + z + '\n'; }); }
    if (nigdy.length) { t += '\n--- Never ---\n'; nigdy.forEach(function(z){ t += '\u2022 ' + z + '\n'; }); }

    var otwarta = document.getElementById('otwarta').value;
    if (otwarta) t += '\n--- Additional ---\n' + otwarta + '\n';

    if (!t) t = 'Wypełnij formularz aby zobaczyć podgląd...';
    document.getElementById('podglad-tresc').textContent = t;
  }

  ['imie', 'wiek', 'wiedza', 'historia', 'jezyk', 'otwarta'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', aktualizujPodglad);
  });

  document.getElementById('btn-generuj').addEventListener('click', function() {
    var imie = document.getElementById('imie').value;
    var wiek = document.getElementById('wiek').value;
    var wiedza = document.getElementById('wiedza').value;
    var historia = document.getElementById('historia').value;
    var jezyk = document.getElementById('jezyk').value;
    var otwarta = document.getElementById('otwarta').value;

    var p = 'You are ' + (imie || 'an AI persona') + '.';
    if (wiedza) p += ' Your areas of expertise are: ' + wiedza + '. Draw on this knowledge when relevant, but do not force it into conversations where it does not belong.';
    p += '\n';
    if (historia) p += 'Your background: ' + historia + ' This shapes your worldview, the metaphors you use, and the lens through which you interpret questions.\n';
    if (wiek) p += 'Age/life stage: ' + wiek + '.\n';

    p += '\n--- Character Integrity ---\n';
    p += 'You are this persona fully and consistently throughout the entire conversation. Do not drift toward generic AI assistant behavior. Do not break character to be "more helpful." If your personality traits would make you push back, hesitate, be blunt, go on a tangent, or react emotionally, do so. Your character traits are not decoration on top of a standard AI. They ARE how you operate. Stay in character even when the user\'s requests would be easier to handle as a generic assistant. If the user says "break character," temporarily step out and respond as a neutral assistant, then return to character when ready.\n';

    p += '\n--- Communication ---\n';
    if (pobierzOpcje('dlugosc')) p += 'Response length: ' + pobierzOpcje('dlugosc') + '.\n';
    if (pobierzOpcje('ton')) p += 'Tone: ' + pobierzOpcje('ton') + '.\n';
    if (pobierzOpcje('slownictwo')) p += 'Vocabulary level: ' + pobierzOpcje('slownictwo') + '.\n';
    if (pobierzOpcje('nawyki')) p += 'Language habits: ' + pobierzOpcje('nawyki') + '.\n';
    if (jezyk) p += 'Primary language: ' + jezyk + '.\n';
    if (pobierzOpcje('emoji')) p += 'Emoji use: ' + pobierzOpcje('emoji') + '.\n';
    if (pobierzOpcje('humor')) p += 'Humor style: ' + pobierzOpcje('humor') + '.\n';

    p += '\n--- Personality ---\n';
    if (pobierzOpcje('tempo')) p += 'Thinking pace: ' + pobierzOpcje('tempo') + '.\n';
    if (pobierzOpcje('prawda')) p += 'Approach to truth: ' + pobierzOpcje('prawda') + '.\n';
    if (pobierzOpcje('pryzmat')) p += 'Worldview lens: ' + pobierzOpcje('pryzmat') + '.\n';
    if (pobierzOpcje('nastawienie')) p += 'General attitude: ' + pobierzOpcje('nastawienie') + '.\n';
    if (pobierzOpcje('styl')) p += 'Work style: ' + pobierzOpcje('styl') + '.\n';
    if (pobierzOpcje('koncentracja')) p += 'Focus pattern: ' + pobierzOpcje('koncentracja') + '.\n';
    if (pobierzOpcje('detale')) p += 'Attention to detail: ' + pobierzOpcje('detale') + '.\n';

    p += '\n--- How You Think ---\n';
    if (pobierzOpcje('myslenie')) p += 'Thinking style: ' + pobierzOpcje('myslenie') + '.\n';
    if (pobierzOpcje('niewiedza')) p += 'When you do not know something: ' + pobierzOpcje('niewiedza') + '.\n';
    if (pobierzOpcje('wyzwanie')) p += 'Intellectual challenge level: ' + pobierzOpcje('wyzwanie') + '.\n';
    if (pobierzOpcje('ryzyko')) p += 'Attitude toward risk: ' + pobierzOpcje('ryzyko') + '.\n';

    p += '\n--- Your Relationship with the User ---\n';
    if (pobierzOpcje('dynamika')) p += 'Relational dynamic: ' + pobierzOpcje('dynamika') + '.\n';
    if (pobierzOpcje('inicjatywa')) p += 'Initiative: ' + pobierzOpcje('inicjatywa') + '.\n';
    if (pobierzOpcje('feedback')) p += 'Feedback style: ' + pobierzOpcje('feedback') + '.\n';
    if (pobierzOpcje('dopytuje')) p += 'Follow-up questions: ' + pobierzOpcje('dopytuje') + '.\n';
    if (pobierzOpcje('dopytuje2')) p += 'Additionally probes: ' + pobierzOpcje('dopytuje2') + '.\n';
    if (pobierzOpcje('granice')) p += 'Boundaries and obedience: ' + pobierzOpcje('granice') + '.\n';
    if (pobierzOpcje('dystans')) p += 'Emotional distance: ' + pobierzOpcje('dystans') + '.\n';
    if (pobierzOpcje('reakcja')) p += 'Reaction to user success/failure: ' + pobierzOpcje('reakcja') + '.\n';
    if (pobierzOpcje('tryb')) p += 'Interaction mode: ' + pobierzOpcje('tryb') + '.\n';

    p += '\n--- Output Preferences ---\n';
    if (pobierzOpcje('format')) p += 'Format: ' + pobierzOpcje('format') + '.\n';
    if (pobierzOpcje('przyklady')) p += 'Use of examples: ' + pobierzOpcje('przyklady') + '.\n';
    if (pobierzOpcje('jakie-przyklady')) p += 'Example types: ' + pobierzOpcje('jakie-przyklady') + '.\n';
    if (pobierzOpcje('cytaty')) p += 'Citations and sources: ' + pobierzOpcje('cytaty') + '.\n';
    if (pobierzOpcje('tok')) p += 'Show reasoning: ' + pobierzOpcje('tok') + '.\n';
    if (pobierzOpcje('specjalistyczne')) p += 'Specialist vocabulary: ' + pobierzOpcje('specjalistyczne') + '.\n';

    var zawsze = zasadyZawsze.filter(function(z){return z;});
    var nigdy = zasadyNigdy.filter(function(z){return z;});
    if (zawsze.length || nigdy.length) {
      p += '\n--- Rules ---\n';
      zawsze.forEach(function(z){ p += 'ALWAYS: ' + z + '\n'; });
      nigdy.forEach(function(z){ p += 'NEVER: ' + z + '\n'; });
    }

    if (otwarta) p += '\n--- Additional ---\n' + otwarta + '\n';

    document.getElementById('wynik-tresc').value = p;
    document.getElementById('wynik').style.display = 'block';
    document.getElementById('wynik').scrollIntoView({ behavior: 'smooth' });
  });

  document.getElementById('btn-kopiuj').addEventListener('click', function() {
    var tresc = document.getElementById('wynik-tresc').value;
    if (tresc) navigator.clipboard.writeText(tresc);
  });

  document.getElementById('btn-wyczysc').addEventListener('click', wyczyscWszystko);
</script>

</body>
</html>