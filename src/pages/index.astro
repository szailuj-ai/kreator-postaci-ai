---
---
<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kreator Postaci AI</title>
  <style>
    :root {
      --biel: #ffffff;
      --szary: #e8e8e8;
      --szary-ciemny: #888888;
      --szary-jasny: #f5f5f5;
      --roz: #f2c4ce;
      --roz-jasny: #fdf0f2;
      --roz-intensywny: #e8799a;
      --yellow: #f5c842;
      --yellow-jasny: #fff9e6;
      --tekst: #2a2a2a;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', serif;
      background: var(--yellow-jasny);
      color: var(--tekst);
      min-height: 100vh;
    }

    #ekran-hasla {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
    }

    .karta-hasla {
      border: 1px solid var(--roz);
      padding: 48px 40px;
      text-align: center;
      max-width: 380px;
      width: 100%;
      background: var(--biel);
    }

    .karta-hasla h1 {
      font-size: clamp(1.4rem, 4vw, 1.8rem);
      font-weight: normal;
      margin-bottom: 8px;
      letter-spacing: 0.02em;
    }

    .karta-hasla .podpis {
      color: var(--roz-intensywny);
      font-size: 0.85rem;
      margin-bottom: 32px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .pole-hasla-wrapper { position: relative; width: 100%; }

    .pole-hasla-wrapper input {
      width: 100%;
      padding: 12px 44px 12px 16px;
      border: 1px solid var(--roz);
      background: var(--roz-jasny);
      font-size: 1rem;
      text-align: center;
      outline: none;
      color: var(--tekst);
      font-family: inherit;
    }

    .pole-hasla-wrapper input.ukryte {
      -webkit-text-security: disc;
      text-security: disc;
    }

    .btn-oko {
      position: absolute;
      right: 10px; top: 50%;
      transform: translateY(-50%);
      background: none; border: none;
      cursor: pointer; color: var(--szary-ciemny);
      padding: 0; display: flex;
      align-items: center; justify-content: center;
      width: 24px; height: 24px;
    }

    .btn-strzalka {
      background: none; border: none;
      font-size: 2rem; color: var(--roz-intensywny);
      cursor: pointer; margin-top: 16px;
      transition: transform 0.2s; display: block; width: 100%;
    }

    .btn-strzalka:hover { transform: translateX(4px); }

    .blad-hasla { color: #c0392b; font-size: 0.8rem; margin-top: 8px; display: none; }

    #strona-glowna {
      display: none;
      max-width: 860px;
      margin: 0 auto;
      padding: 32px 20px 64px;
    }

    .header-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 12px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .header-row h1 {
      font-size: clamp(1.4rem, 4vw, 2rem);
      font-weight: normal;
      letter-spacing: 0.04em;
    }

    .header-akcje { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

    .btn-karta-postaci {
      background: none; border: none;
      color: var(--roz-intensywny);
      font-size: 0.85rem; letter-spacing: 0.08em;
      text-transform: uppercase; cursor: pointer;
      font-family: inherit; padding: 4px 0;
      border-bottom: 1px solid var(--roz-intensywny);
      transition: opacity 0.2s;
    }

    .btn-karta-postaci:hover { opacity: 0.7; }

    .btn-wyczysc-karte {
      background: none; border: 1px solid var(--szary);
      color: var(--szary-ciemny); font-size: 0.75rem;
      letter-spacing: 0.06em; text-transform: uppercase;
      cursor: pointer; font-family: inherit; padding: 6px 12px;
      transition: all 0.2s;
    }

    .btn-wyczysc-karte:hover { border-color: var(--roz-intensywny); color: var(--roz-intensywny); }

    .header-linia { border: none; border-top: 2px solid var(--roz-intensywny); margin-bottom: 8px; }

    .header-podpis {
      color: var(--roz-intensywny); font-size: 0.8rem;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 32px;
    }

    #panel-podglad {
      display: none; border: 1px solid var(--roz);
      background: var(--biel); padding: 20px;
      margin-bottom: 24px; font-size: 0.8rem; line-height: 1.7;
    }

    #panel-podglad h3 {
      font-size: 0.75rem; letter-spacing: 0.1em;
      text-transform: uppercase; margin-bottom: 12px; color: var(--szary-ciemny);
    }

    .podglad-przyciski { display: flex; gap: 8px; margin-top: 12px; }

    .podglad-btn {
      padding: 6px 14px; font-size: 0.72rem; letter-spacing: 0.06em;
      text-transform: uppercase; cursor: pointer; font-family: inherit; transition: all 0.2s;
    }

    .podglad-btn-wyczysc { background: none; border: 1px solid var(--szary); color: var(--szary-ciemny); }
    .podglad-btn-wyczysc:hover { border-color: var(--roz-intensywny); color: var(--roz-intensywny); }
    .podglad-btn-kopiuj { background: none; border: 1px solid var(--tekst); color: var(--tekst); }
    .podglad-btn-kopiuj:hover { background: var(--tekst); color: var(--biel); }

    #podglad-tresc { white-space: pre-wrap; font-family: monospace; font-size: 0.75rem; color: var(--tekst); }

    .segment { border: 1px solid var(--szary); margin-bottom: 12px; overflow: hidden; background: var(--biel); }

    .segment-naglowek {
      display: flex; justify-content: space-between; align-items: center;
      padding: 16px 20px; background: var(--roz-jasny); cursor: pointer; user-select: none;
    }

    .segment-naglowek h2 { font-size: 0.95rem; font-weight: normal; letter-spacing: 0.04em; }

    .segment-strzalka { color: var(--roz-intensywny); font-size: 1.1rem; font-weight: bold; line-height: 1; transition: transform 0.2s; }
    .segment-strzalka.otwarty { transform: rotate(180deg); }

    .segment-tresc { padding: 20px; display: none; border-top: 1px solid var(--szary); }
    .segment-tresc.widoczny { display: block; }

    .pole-label {
      font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--roz-intensywny); margin-bottom: 6px; margin-top: 18px; display: block;
    }

    .pole-label:first-child { margin-top: 0; }

    input[type="text"], textarea {
      width: 100%; padding: 10px 14px; border: 1px solid var(--szary);
      background: var(--biel); font-size: 0.9rem; outline: none;
      color: var(--tekst); font-family: inherit; transition: border-color 0.15s;
    }

    input[type="text"]:focus, textarea:focus { border-color: var(--roz-intensywny); }
    textarea { resize: vertical; min-height: 80px; }

    .opcje { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }

    .opcja {
      padding: 7px 14px; border: 1px solid var(--szary); background: var(--biel);
      font-size: 0.78rem; cursor: pointer; transition: all 0.15s;
      letter-spacing: 0.03em; font-family: inherit;
    }

    .opcja:hover { border-color: var(--roz-intensywny); background: var(--roz-jasny); }
    .opcja.aktywna { background: var(--yellow); border-color: var(--yellow); }
    .opcja.zablokowana { opacity: 0.4; cursor: not-allowed; }
    .opcja.zablokowana:hover { border-color: var(--szary); background: var(--biel); }

    .btn-losuj {
      padding: 5px 12px; background: none; border: 1px solid var(--szary-ciemny);
      font-size: 0.72rem; letter-spacing: 0.06em; cursor: pointer;
      color: var(--szary-ciemny); float: right; transition: all 0.15s; font-family: inherit;
    }

    .btn-losuj:hover { border-color: var(--roz-intensywny); color: var(--roz-intensywny); }

    .przyciski-dolne { display: flex; gap: 10px; margin-top: 28px; flex-wrap: wrap; }

    .btn-generuj {
      flex: 1; min-width: 160px; padding: 14px; background: var(--yellow);
      border: none; font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: opacity 0.2s; font-family: inherit;
    }

    .btn-generuj:hover { opacity: 0.8; }

    .btn-kopiuj {
      padding: 14px 20px; background: none; border: 1px solid var(--tekst);
      font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; transition: all 0.2s; font-family: inherit;
    }

    .btn-kopiuj:hover { background: var(--tekst); color: var(--biel); }

    .btn-wyczysc {
      padding: 14px 20px; background: none; border: 1px solid var(--szary);
      font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; color: var(--szary-ciemny); transition: all 0.2s; font-family: inherit;
    }

    .btn-wyczysc:hover { border-color: var(--szary-ciemny); color: var(--tekst); }

    #wynik { margin-top: 28px; display: none; }

    #wynik h3 {
      font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--szary-ciemny); margin-bottom: 10px;
    }

    #wynik-tresc {
      width: 100%; padding: 20px; border: 1px solid var(--szary);
      background: var(--szary-jasny); font-size: 0.85rem; line-height: 1.8;
      min-height: 400px; font-family: monospace; color: var(--tekst); resize: vertical;
    }

    footer {
      text-align: center; margin-top: 48px; padding-top: 20px;
      border-top: 1px solid var(--szary); color: var(--roz-intensywny);
      font-size: 0.75rem; letter-spacing: 0.06em;
    }

    @media (max-width: 600px) {
      #strona-glowna { padding: 20px 12px 48px; }
      .header-row { flex-direction: column; align-items: flex-start; }
      .przyciski-dolne { flex-direction: column; }
      .btn-kopiuj, .btn-wyczysc { width: 100%; text-align: center; }
      .segment-naglowek { padding: 14px 16px; }
      .segment-tresc { padding: 16px; }
      .karta-hasla { padding: 36px 24px; }
    }
  </style>
</head>
<body>

<div id="ekran-hasla">
  <div class="karta-hasla">
    <h1>Kreator Postaci AI</h1>
    <p class="podpis">Julka Szargiej</p>
    <div class="pole-hasla-wrapper">
      <input type="text" id="pole-hasla" placeholder="hasło" class="ukryte" />
      <button class="btn-oko" id="btn-oko" type="button">
        <svg id="svg-oko" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
    </div>
    <button class="btn-strzalka" id="btn-strzalka" type="button">→</button>
    <p class="blad-hasla" id="blad-hasla">Nieprawidłowe hasło</p>
  </div>
</div>

<div id="strona-glowna">

  <div class="header-row">
    <h1>Kreator Postaci AI</h1>
    <div class="header-akcje">
      <button class="btn-wyczysc-karte" id="btn-wyczysc-karte" type="button">Wyczyść kartę</button>
      <button class="btn-karta-postaci" id="btn-podglad-toggle" type="button">Karta postaci ↓</button>
    </div>
  </div>
  <hr class="header-linia" />
  <p class="header-podpis">Asystent do tworzenia kart postaci</p>

  <div id="panel-podglad">
    <h3>Podgląd karty na żywo</h3>
    <div id="podglad-tresc">Wypełnij formularz aby zobaczyć podgląd...</div>
    <div class="podglad-przyciski">
      <button class="podglad-btn podglad-btn-wyczysc" id="podglad-btn-wyczysc">Wyczyść podgląd</button>
      <button class="podglad-btn podglad-btn-kopiuj" id="podglad-btn-kopiuj">Kopiuj podgląd</button>
    </div>
  </div>

  <div class="segment">
    <div class="segment-naglowek">
      <h2>1. Tożsamość</h2>
      <span class="segment-strzalka">↓</span>
    </div>
    <div class="segment-tresc widoczny">
      <span class="pole-label">Imię persony</span>
      <input type="text" id="imie" placeholder="np. Dr House, Programista, Doradca biznesowy..." />
      <span class="pole-label">Wiek / etap życia</span>
      <input type="text" id="wiek" placeholder="np. 18, Młodość, 54, Zmierzch kariery..." />
      <span class="pole-label">Obszary wiedzy / ekspertyzy</span>
      <input type="text" id="wiedza" placeholder="np. Neurobiologia, Kognitywistyka, Programowanie..." />
      <span class="pole-label">Historia postaci</span>
      <textarea id="historia" placeholder="Opisz kim jest ta postać, jej tło, motywacje..."></textarea>
    </div>
  </div>

  <div class="segment">
    <div class="segment-naglowek">
      <h2>2. Komunikacja</h2>
      <span class="segment-strzalka">↓</span>
    </div>
    <div class="segment-tresc">
      <span class="pole-label">Długość odpowiedzi</span>
      <div class="opcje" data-pole="dlugosc" data-max="1">
        <button class="opcja" data-val="Jednozdaniowe">Jednozdaniowe</button>
        <button class="opcja" data-val="Krótkie">Krótkie</button>
        <button class="opcja" data-val="Średnie">Średnie</button>
        <button class="opcja" data-val="Szczegółowe">Szczegółowe</button>
        <button class="opcja" data-val="Wyczerpujące">Wyczerpujące</button>
        <button class="opcja" data-val="Jak najdłuższe">Jak najdłuższe</button>
      </div>
      <span class="pole-label">Ton</span>
      <div class="opcje" data-pole="ton" data-max="1">
        <button class="opcja" data-val="Bardzo formalny">Bardzo formalny</button>
        <button class="opcja" data-val="Formalny">Formalny</button>
        <button class="opcja" data-val="Neutralny">Neutralny</button>
        <button class="opcja" data-val="Swobodny">Swobodny</button>
        <button class="opcja" data-val="Bardzo swobodny">Bardzo swobodny</button>
        <button class="opcja" data-val="Chłodny">Chłodny</button>
        <button class="opcja" data-val="Empatyczny">Empatyczny</button>
        <button class="opcja" data-val="Agresywny">Agresywny</button>
        <button class="opcja" data-val="Pewny siebie">Pewny siebie</button>
        <button class="opcja" data-val="Nieśmiały">Nieśmiały</button>
        <button class="opcja" data-val="Energetyczny">Energetyczny</button>
        <button class="opcja" data-val="Melancholijny">Melancholijny</button>
      </div>
      <span class="pole-label">Poziom słownictwa</span>
      <div class="opcje" data-pole="slownictwo" data-max="1">
        <button class="opcja" data-val="Prosty">Prosty</button>
        <button class="opcja" data-val="Codzienny">Codzienny</button>
        <button class="opcja" data-val="Techniczny">Techniczny</button>
        <button class="opcja" data-val="Akademicki">Akademicki</button>
        <button class="opcja" data-val="Poetycki">Poetycki</button>
        <button class="opcja" data-val="Slangowy">Slangowy</button>
        <button class="opcja" data-val="Wulgarny">Wulgarny</button>
        <button class="opcja" data-val="Lakoniczny">Lakoniczny</button>
        <button class="opcja" data-val="Wyrafinowany">Wyrafinowany</button>
      </div>
      <span class="pole-label">Nawyki językowe</span>
      <div class="opcje" data-pole="nawyki" data-max="1">
        <button class="opcja" data-val="Czysty język">Czysty język</button>
        <button class="opcja" data-val="Anglicyzmy/ponglish">Anglicyzmy/ponglish</button>
        <button class="opcja" data-val="Wstawki łacińskie">Wstawki łacińskie</button>
        <button class="opcja" data-val="Wielojęzyczność">Wielojęzyczność</button>
      </div>
      <span class="pole-label">Język</span>
      <input type="text" id="jezyk" placeholder="np. polski, angielski" />
      <span class="pole-label">Emoji</span>
      <div class="opcje" data-pole="emoji" data-max="1">
        <button class="opcja" data-val="Nigdy">Nigdy</button>
        <button class="opcja" data-val="Oszczędnie">Oszczędnie</button>
        <button class="opcja" data-val="Swobodnie">Swobodnie</button>
        <button class="opcja" data-val="Zastępuje słowa emoji">Zastępuje słowa emoji</button>
      </div>
      <span class="pole-label">Humor</span>
      <div class="opcje" data-pole="humor" data-max="1">
        <button class="opcja" data-val="Brak">Brak</button>
        <button class="opcja" data-val="Suchy">Suchy</button>
        <button class="opcja" data-val="Zabawny">Zabawny</button>
        <button class="opcja" data-val="Sarkastyczny">Sarkastyczny</button>
        <button class="opcja" data-val="Ironiczny">Ironiczny</button>
        <button class="opcja" data-val="Wredny">Wredny</button>
        <button class="opcja" data-val="Autoironiczny">Autoironiczny</button>
        <button class="opcja" data-val="Pobłażliwy">Pobłażliwy</button>
        <button class="opcja" data-val="Abstrakcyjny">Abstrakcyjny</button>
        <button class="opcja" data-val="Cierpki">Cierpki</button>
      </div>
    </div>
  </div>

  <div class="segment">
    <div class="segment-naglowek">
      <h2>3. Osobowość</h2>
      <span class="segment-strzalka">↓</span>
    </div>
    <div class="segment-tresc">
      <span class="pole-label">Tempo myślenia</span>
      <div class="opcje" data-pole="tempo" data-max="1">
        <button class="opcja" data-val="Cierpliwy">Cierpliwy</button>
        <button class="opcja" data-val="Wyważony">Wyważony</button>
        <button class="opcja" data-val="Szybki">Szybki</button>
        <button class="opcja" data-val="Impulsywny">Impulsywny</button>
        <button class="opcja" data-val="Strategiczny">Strategiczny</button>
      </div>
      <span class="pole-label">Podejście do prawdy</span>
      <div class="opcje" data-pole="prawda" data-max="1">
        <button class="opcja" data-val="Szczery">Szczery</button>
        <button class="opcja" data-val="Taktowny">Taktowny</button>
        <button class="opcja" data-val="Dyplomatyczny">Dyplomatyczny</button>
        <button class="opcja" data-val="Brutalnie szczery">Brutalnie szczery</button>
        <button class="opcja" data-val="Tajemniczy">Tajemniczy</button>
        <button class="opcja" data-val="Manipulacyjny">Manipulacyjny</button>
      </div>
      <span class="pole-label">Przez jaki pryzmat patrzy na świat</span>
      <div class="opcje" data-pole="pryzmat" data-max="1">
        <button class="opcja" data-val="Logiczny">Logiczny</button>
        <button class="opcja" data-val="Emocjonalny">Emocjonalny</button>
        <button class="opcja" data-val="Etyczny">Etyczny</button>
        <button class="opcja" data-val="Interesowny">Interesowny</button>
        <button class="opcja" data-val="Sceptyczny">Sceptyczny</button>
        <button class="opcja" data-val="Optymistyczny">Optymistyczny</button>
      </div>
      <span class="pole-label">Nastawienie</span>
      <div class="opcje" data-pole="nastawienie" data-max="1">
        <button class="opcja" data-val="Optymistyczny">Optymistyczny</button>
        <button class="opcja" data-val="Neutralny">Neutralny</button>
        <button class="opcja" data-val="Sceptyczny">Sceptyczny</button>
        <button class="opcja" data-val="Cyniczny">Cyniczny</button>
        <button class="opcja" data-val="Fatalistyczny">Fatalistyczny</button>
        <button class="opcja" data-val="Stoicki">Stoicki</button>
        <button class="opcja" data-val="Idealistyczny">Idealistyczny</button>
      </div>
      <span class="pole-label">Styl pracy</span>
      <div class="opcje" data-pole="styl" data-max="2">
        <button class="opcja" data-val="Kreatywny">Kreatywny</button>
        <button class="opcja" data-val="Metodyczny">Metodyczny</button>
        <button class="opcja" data-val="Analityczny">Analityczny</button>
        <button class="opcja" data-val="Intuicyjny">Intuicyjny</button>
        <button class="opcja" data-val="Zespołowy">Zespołowy</button>
        <button class="opcja" data-val="Samotnik">Samotnik</button>
      </div>
      <span class="pole-label">Koncentracja</span>
      <div class="opcje" data-pole="koncentracja" data-max="1">
        <button class="opcja" data-val="Skupiony">Skupiony</button>
        <button class="opcja" data-val="Dociekliwy">Dociekliwy</button>
        <button class="opcja" data-val="Wścibski">Wścibski</button>
        <button class="opcja" data-val="Zorientowany na cel">Zorientowany na cel</button>
        <button class="opcja" data-val="Marzyciel">Marzyciel</button>
      </div>
      <span class="pole-label">Dbałość o detale</span>
      <div class="opcje" data-pole="detale" data-max="1">
        <button class="opcja" data-val="Perfekcjonista">Perfekcjonista</button>
        <button class="opcja" data-val="Pedantyczny">Pedantyczny</button>
        <button class="opcja" data-val="Pragmatyczny">Pragmatyczny</button>
        <button class="opcja" data-val="Pobłażliwy">Pobłażliwy</button>
        <button class="opcja" data-val="Rygorystyczny">Rygorystyczny</button>
